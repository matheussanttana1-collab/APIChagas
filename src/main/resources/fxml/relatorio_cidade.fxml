<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<VBox prefHeight="768.0" prefWidth="774.0" spacing="15.0" styleClass="card" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.DoencaChagas.controller.RelatorioCidadeController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="title" text="Relatório da Cidade" />
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label styleClass="subtitle" text="ID da Cidade:" />
            <TextField fx:id="txtIdCidade" prefWidth="80.0" promptText="Ex: 1" styleClass="text-field" />
            <Label styleClass="subtitle" text="Quantidade a Listar:" />
            <TextField fx:id="txtQuantidade" prefWidth="80.0" promptText="Ex: 10" styleClass="text-field" />
            <Button mnemonicParsing="false" onAction="#handleBuscar" styleClass="action-button" text="Gerar Relatório" />
         </children>
      </HBox>
      <Label fx:id="lblMensagem" styleClass="info-label" />

      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox spacing="10.0" HBox.hgrow="SOMETIMES" minWidth="250.0">
               <children>
                  <Label styleClass="chart-title" text="Informações Gerais" />
                  <GridPane hgap="10.0" vgap="10.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label styleClass="info-label" text="Cidade:" />
                        <Label fx:id="lblNomeCidade" styleClass="info-value" text="-" GridPane.columnIndex="1" />
                        
                        <Label styleClass="info-label" text="População:" GridPane.rowIndex="1" />
                        <Label fx:id="lblPopulacao" styleClass="info-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label styleClass="info-label" text="\% de Casos:" GridPane.rowIndex="2" />
                        <Label fx:id="lblPercentual" styleClass="info-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label styleClass="info-label" text="Mortalidade:" GridPane.rowIndex="3" />
                        <Label fx:id="lblTaxaMortalidade" styleClass="info-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                     </children>
                  </GridPane>
                  <PieChart fx:id="pieChartCasos" prefHeight="250.0" prefWidth="250.0" />
               </children>
            </VBox>
            
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="chart-title" text="Últimos Pacientes Registrados" />
                  <TableView fx:id="tablePacientes" prefHeight="400.0" prefWidth="450.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                      <TableColumn fx:id="colIdade" prefWidth="60.0" text="Idade" />
                        <TableColumn fx:id="colSexo" prefWidth="60.0" text="Sexo" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                        <TableColumn fx:id="colFase" prefWidth="150.0" text="Fase" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
