<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="774.0" spacing="15.0" styleClass="card" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.DoencaChagas.controller.RelatorioGeralController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="title" text="Relatório Geral (Todas as Cidades)" />
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label styleClass="subtitle" text="Data Inicial:" />
            <DatePicker fx:id="dpDataInicial" prefWidth="130.0" promptText="dd/MM/yyyy" styleClass="date-picker" />
            <Label styleClass="subtitle" text="Data Final:" />
            <DatePicker fx:id="dpDataFinal" prefWidth="130.0" promptText="dd/MM/yyyy" styleClass="date-picker" />
            <Button mnemonicParsing="false" onAction="#handleBuscar" styleClass="action-button" text="Gerar Relatório" />
         </children>
      </HBox>
      <Label fx:id="lblMensagem" styleClass="info-label" />

      <TableView fx:id="tableRelatorio" prefHeight="400.0" prefWidth="734.0" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colCidade" prefWidth="140.0" text="Cidade" />
          <TableColumn fx:id="colPopulacao" prefWidth="90.0" text="População" />
            <TableColumn fx:id="colConfirmados" prefWidth="90.0" text="Confirmados" />
            <TableColumn fx:id="colSuspeitos" prefWidth="85.0" text="Suspeitos" />
            <TableColumn fx:id="colRecuperados" prefWidth="90.0" text="Recuperados" />
            <TableColumn fx:id="colObitos" prefWidth="85.0" text="Óbitos" />
            <TableColumn fx:id="colMortalidade" prefWidth="120.0" text="Mortalidade" />
        </columns>
      </TableView>
   </children>
</VBox>
