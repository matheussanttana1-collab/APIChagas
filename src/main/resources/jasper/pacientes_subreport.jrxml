	<parameter name="ID_CIDADE" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[SELECT
    p.id_paciente,
    p.idade,
    p.sexo,
    p.fase_doenca,
    p.forma_clinica,
    p.via_transmissao,
    p.status_paciente
FROM pacientes p
WHERE p.id_cidade = $P{ID_CIDADE}]]>
	</queryString>
