<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="relatorio_comparativo_cidades_idade" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="0.75"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	
	<parameter name="CIDADE1_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="CIDADE2_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	
	<queryString>
		<![CDATA[SELECT
    faixa_etaria,
    ordem_faixa,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN total_pacientes ELSE 0 END) as c1_total,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN confirmados ELSE 0 END) as c1_confirmados,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN suspeitos ELSE 0 END) as c1_suspeitos,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN recuperados ELSE 0 END) as c1_recuperados,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN obitos ELSE 0 END) as c1_obitos,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN masculino ELSE 0 END) as c1_masculino,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN feminino ELSE 0 END) as c1_feminino,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN fase_aguda ELSE 0 END) as c1_aguda,
    SUM(CASE WHEN id_cidade = $P{CIDADE1_ID} THEN fase_cronica ELSE 0 END) as c1_cronica,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN total_pacientes ELSE 0 END) as c2_total,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN confirmados ELSE 0 END) as c2_confirmados,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN suspeitos ELSE 0 END) as c2_suspeitos,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN recuperados ELSE 0 END) as c2_recuperados,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN obitos ELSE 0 END) as c2_obitos,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN masculino ELSE 0 END) as c2_masculino,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN feminino ELSE 0 END) as c2_feminino,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN fase_aguda ELSE 0 END) as c2_aguda,
    SUM(CASE WHEN id_cidade = $P{CIDADE2_ID} THEN fase_cronica ELSE 0 END) as c2_cronica,
    (SELECT nome FROM cidades WHERE id_cidade = $P{CIDADE1_ID}) as cidade1_nome,
    (SELECT nome FROM cidades WHERE id_cidade = $P{CIDADE2_ID}) as cidade2_nome
FROM
(
    SELECT
        CASE
            WHEN idade < 5 THEN '0-4 anos'
            WHEN idade >= 5 AND idade <= 9 THEN '5-9 anos'
            WHEN idade >= 10 AND idade <= 19 THEN '10-19 anos'
            WHEN idade >= 20 AND idade <= 29 THEN '20-29 anos'
            WHEN idade >= 30 AND idade <= 39 THEN '30-39 anos'
            WHEN idade >= 40 AND idade <= 49 THEN '40-49 anos'
            WHEN idade >= 50 AND idade <= 59 THEN '50-59 anos'
            WHEN idade >= 60 AND idade <= 69 THEN '60-69 anos'
            WHEN idade >= 70 THEN '70+ anos'
            ELSE 'Sem informação'
        END as faixa_etaria,
        CASE
            WHEN idade < 5 THEN 1
            WHEN idade >= 5 AND idade <= 9 THEN 2
            WHEN idade >= 10 AND idade <= 19 THEN 3
            WHEN idade >= 20 AND idade <= 29 THEN 4
            WHEN idade >= 30 AND idade <= 39 THEN 5
            WHEN idade >= 40 AND idade <= 49 THEN 6
            WHEN idade >= 50 AND idade <= 59 THEN 7
            WHEN idade >= 60 AND idade <= 69 THEN 8
            WHEN idade >= 70 THEN 9
            ELSE 10
        END as ordem_faixa,
        id_cidade,
        COUNT(*) as total_pacientes,
        SUM(CASE WHEN status_paciente='CONFIRMADO' THEN 1 ELSE 0 END) as confirmados,
        SUM(CASE WHEN status_paciente='SUSPEITO' THEN 1 ELSE 0 END) as suspeitos,
        SUM(CASE WHEN status_paciente='RECUPERADO' THEN 1 ELSE 0 END) as recuperados,
        SUM(CASE WHEN status_paciente='OBITO' THEN 1 ELSE 0 END) as obitos,
        SUM(CASE WHEN sexo='M' THEN 1 ELSE 0 END) as masculino,
        SUM(CASE WHEN sexo='F' THEN 1 ELSE 0 END) as feminino,
        SUM(CASE WHEN fase_doenca='AGUDA' THEN 1 ELSE 0 END) as fase_aguda,
        SUM(CASE WHEN fase_doenca='CRONICA' THEN 1 ELSE 0 END) as fase_cronica
    FROM pacientes
    WHERE id_cidade IN ($P{CIDADE1_ID}, $P{CIDADE2_ID})
    GROUP BY faixa_etaria, ordem_faixa, id_cidade
) dados
GROUP BY faixa_etaria, ordem_faixa
ORDER BY ordem_faixa]]>
	</queryString>
	
