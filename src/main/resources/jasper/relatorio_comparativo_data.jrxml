				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[Gráfico Comparativo: Casos Confirmados e Suspeitos por Data de Coleta]]></text>
			</staticText>
			
			<lineChart>
				<chart evaluationTime="Report">
					<reportElement x="10" y="30" width="782" height="185"/>
					<chartTitle/>
