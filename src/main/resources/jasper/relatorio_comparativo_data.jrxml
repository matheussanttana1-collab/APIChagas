<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="relatorio_comparativo_cidades_data" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="0.75"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	
	<parameter name="CIDADE1_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="CIDADE2_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[2]]></defaultValueExpression>
	</parameter>
	
	<queryString>
		<![CDATA[SELECT
    COALESCE(c1.data_coleta, c2.data_coleta) as data_coleta,
    c1.casos_novos as c1_casos_novos,
    c1.casos_confirmados as c1_confirmados,
    c1.casos_suspeitos as c1_suspeitos,
    c1.obitos as c1_obitos,
    c1.recuperados as c1_recuperados,
    c2.casos_novos as c2_casos_novos,
    c2.casos_confirmados as c2_confirmados,
    c2.casos_suspeitos as c2_suspeitos,
    c2.obitos as c2_obitos,
    c2.recuperados as c2_recuperados,
    (SELECT nome FROM cidades WHERE id_cidade = $P{CIDADE1_ID} LIMIT 1) as cidade1_nome,
    (SELECT nome FROM cidades WHERE id_cidade = $P{CIDADE2_ID} LIMIT 1) as cidade2_nome
FROM coletas c1
LEFT JOIN coletas c2 ON c1.data_coleta = c2.data_coleta AND c2.id_cidade = $P{CIDADE2_ID}
WHERE c1.id_cidade = $P{CIDADE1_ID}

UNION ALL

SELECT
    c2.data_coleta as data_coleta,
    NULL as c1_casos_novos,
    NULL as c1_confirmados,
    NULL as c1_suspeitos,
    NULL as c1_obitos,
    NULL as c1_recuperados,
    c2.casos_novos as c2_casos_novos,
    c2.casos_confirmados as c2_confirmados,
    c2.casos_suspeitos as c2_suspeitos,
    c2.obitos as c2_obitos,
    c2.recuperados as c2_recuperados,
    (SELECT nome FROM cidades WHERE id_cidade = $P{CIDADE1_ID} LIMIT 1) as cidade1_nome,
    (SELECT nome FROM cidades WHERE id_cidade = $P{CIDADE2_ID} LIMIT 1) as cidade2_nome
FROM coletas c2
LEFT JOIN coletas c1 ON c2.data_coleta = c1.data_coleta AND c1.id_cidade = $P{CIDADE1_ID}
WHERE c2.id_cidade = $P{CIDADE2_ID} AND c1.id_coleta IS NULL

ORDER BY data_coleta]]>
	</queryString>
	
	<field name="data_coleta" class="java.sql.Date"/>
	<field name="c1_casos_novos" class="java.lang.Integer"/>
	<field name="c1_confirmados" class="java.lang.Integer"/>
	<field name="c1_suspeitos" class="java.lang.Integer"/>
	<field name="c1_obitos" class="java.lang.Integer"/>
	<field name="c1_recuperados" class="java.lang.Integer"/>
	<field name="c2_casos_novos" class="java.lang.Integer"/>
	<field name="c2_confirmados" class="java.lang.Integer"/>
	<field name="c2_suspeitos" class="java.lang.Integer"/>
	<field name="c2_obitos" class="java.lang.Integer"/>
	<field name="c2_recuperados" class="java.lang.Integer"/>
	<field name="cidade1_nome" class="java.lang.String"/>
	<field name="cidade2_nome" class="java.lang.String"/>

