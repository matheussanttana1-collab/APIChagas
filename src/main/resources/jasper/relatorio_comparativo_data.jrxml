				<categoryDataset>
					<categorySeries>
						<seriesExpression><![CDATA["Confirmados " + $F{cidade1_nome}]]></seriesExpression>
						<categoryExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM").format($F{data_coleta})]]></categoryExpression>
						<valueExpression><![CDATA[$F{c1_confirmados} != null ? $F{c1_confirmados} : 0]]></valueExpression>
					</categorySeries>
					<categorySeries>
						<seriesExpression><![CDATA["Confirmados " + $F{cidade2_nome}]]></seriesExpression>
						<categoryExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM").format($F{data_coleta})]]></categoryExpression>
						<valueExpression><![CDATA[$F{c2_confirmados} != null ? $F{c2_confirmados} : 0]]></valueExpression>
					</categorySeries>
					<categorySeries>
						<seriesExpression><![CDATA["Suspeitos " + $F{cidade1_nome}]]></seriesExpression>
						<categoryExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM").format($F{data_coleta})]]></categoryExpression>
						<valueExpression><![CDATA[$F{c1_suspeitos} != null ? $F{c1_suspeitos} : 0]]></valueExpression>
					</categorySeries>
					<categorySeries>
						<seriesExpression><![CDATA["Suspeitos " + $F{cidade2_nome}]]></seriesExpression>
						<categoryExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM").format($F{data_coleta})]]></categoryExpression>
						<valueExpression><![CDATA[$F{c2_suspeitos} != null ? $F{c2_suspeitos} : 0]]></valueExpression>
					</categorySeries>
				</categoryDataset>
				<linePlot>
