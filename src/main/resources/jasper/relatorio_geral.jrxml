	<property name="ireport.y" value="0"/>
	<style name="TitleStyle" forecolor="#003366" fontSize="18" isBold="true"/>
	<style name="CardTitle" forecolor="#FFFFFF" fontSize="12" isBold="true"/>
	<style name="LabelStyle" forecolor="#333333" fontSize="10" isBold="true"/>
	<style name="ValueStyle" forecolor="#000000" fontSize="10"/>
	<style name="CardValueStyle" forecolor="#FFFFFF" fontSize="14" isBold="true"/>
	<style name="CardLegendStyle" forecolor="#FFFFFF" fontSize="9" isBold="true"/>
	<queryString>
		<![CDATA[SELECT
			COUNT(*) as total_pacientes,
			SUM(CASE WHEN status_paciente='CONFIRMADO' THEN 1 ELSE 0 END) as confirmados,
			SUM(CASE WHEN status_paciente='SUSPEITO' THEN 1 ELSE 0 END) as suspeitos,
			SUM(CASE WHEN status_paciente='RECUPERADO' THEN 1 ELSE 0 END) as recuperados,
			SUM(CASE WHEN status_paciente='OBITO' THEN 1 ELSE 0 END) as obitos,
			ROUND(AVG(idade), 1) as media_idade,
			MIN(idade) as idade_minima,
			MAX(idade) as idade_maxima,
			SUM(CASE WHEN sexo='M' THEN 1 ELSE 0 END) as total_masculino,
			SUM(CASE WHEN sexo='F' THEN 1 ELSE 0 END) as total_feminino,
			SUM(CASE WHEN fase_doenca='AGUDA' THEN 1 ELSE 0 END) as fase_aguda,
			SUM(CASE WHEN fase_doenca='CRONICA' THEN 1 ELSE 0 END) as fase_cronica,
			SUM(CASE WHEN forma_clinica='CARDIACA' THEN 1 ELSE 0 END) as forma_cardiaca,
			SUM(CASE WHEN forma_clinica='DIGESTIVA' THEN 1 ELSE 0 END) as forma_digestiva,
			SUM(CASE WHEN forma_clinica='INDETERMINADA' THEN 1 ELSE 0 END) as forma_indeterminada,
			SUM(CASE WHEN forma_clinica='MISTA' THEN 1 ELSE 0 END) as forma_mista,
			SUM(CASE WHEN via_transmissao='VETORIAL' THEN 1 ELSE 0 END) as via_vetorial,
			SUM(CASE WHEN via_transmissao='ORAL' THEN 1 ELSE 0 END) as via_oral,
			SUM(CASE WHEN via_transmissao='VERTICAL' THEN 1 ELSE 0 END) as via_vertical,
			SUM(CASE WHEN via_transmissao='TRANSFUSIONAL' THEN 1 ELSE 0 END) as via_transfusional
		FROM pacientes]]>
	</queryString>
	<field name="total_pacientes" class="java.lang.Long"/>
	<field name="confirmados" class="java.math.BigDecimal"/>
	<field name="suspeitos" class="java.math.BigDecimal"/>
	<field name="recuperados" class="java.math.BigDecimal"/>
	<field name="obitos" class="java.math.BigDecimal"/>
	<field name="media_idade" class="java.math.BigDecimal"/>
	<field name="idade_minima" class="java.lang.Integer"/>
	<field name="idade_maxima" class="java.lang.Integer"/>
	<field name="total_masculino" class="java.math.BigDecimal"/>
