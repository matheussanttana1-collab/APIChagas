	<parameter name="ID_CIDADE" class="java.lang.Integer"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
			c.id_cidade,
			c.nome,
			c.populacao,
			c.regiao,
			COUNT(DISTINCT cl.data_coleta) as total_coletas,
			SUM(cl.casos_novos) as casos_novos,
			SUM(cl.casos_confirmados) as confirmados,
			SUM(cl.casos_suspeitos) as suspeitos,
			SUM(cl.obitos) as obitos,
			SUM(cl.recuperados) as recuperados
		FROM cidades c
		LEFT JOIN coletas cl ON c.id_cidade = cl.id_cidade
		WHERE c.id_cidade = $P{ID_CIDADE}
		GROUP BY c.id_cidade, c.nome, c.populacao, c.regiao]]>
	</queryString>
	<field name="id_cidade" class="java.lang.Integer"/>
	<field name="nome" class="java.lang.String"/>
	<field name="populacao" class="java.lang.Integer"/>
	<field name="regiao" class="java.lang.String"/>
	<field name="total_coletas" class="java.lang.Long"/>
	<field name="casos_novos" class="java.lang.Long"/>
	<field name="confirmados" class="java.lang.Long"/>
	<field name="suspeitos" class="java.lang.Long"/>
	<field name="obitos" class="java.lang.Long"/>
	<field name="recuperados" class="java.lang.Long"/>
